# ─── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_secret
POSTGRES_DB=content_pipeline
DATABASE_URL="postgresql://pipeline:pipeline_secret@localhost:5432/content_pipeline?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (Clerk) ───────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_                           # Backend uses this to verify Clerk JWTs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_          # Frontend Clerk widget
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Object Storage (S3 / Cloudflare R2) ────────────────────────────────────────
S3_BUCKET_NAME=content-pipeline
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=                  # Leave blank for AWS S3; set for Cloudflare R2

# ─── AI / LLM ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-

# ─── OpenAI (Whisper STT for captions) ──────────────────────────────────────────
OPENAI_API_KEY=sk-

# ─── ElevenLabs (Audio) ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── HeyGen (Video) ─────────────────────────────────────────────────────────────
HEYGEN_API_KEY=

# ─── Social Platform OAuth ───────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

META_APP_ID=
META_APP_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Buffer (Fallback Scheduler) ────────────────────────────────────────────────
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=
ENABLE_BUFFER_INTEGRATION=false   # Feature flag — unverified API

# ─── App ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000  # Set to your Vercel URL in production
PORT=3001                           # Injected automatically by Railway/Render in production
API_PORT=3001                       # Fallback for local dev
NODE_ENV=development
